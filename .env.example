# ============================================================
# wp-lemp-docker Configuration
# ============================================================

# --- Domain ---
# Your domain name (without www)
DOMAIN=example.com

# --- MariaDB ---
# Database connection settings
MARIADB_HOST=mariadb
MARIADB_DATABASE=wordpress
MARIADB_USER=wordpress
# CHANGE THIS: Database user password
MARIADB_PASSWORD=changeme
# CHANGE THIS: MariaDB root password
MARIADB_ROOT_PASSWORD=changeme

# --- WordPress ---
# WordPress installation settings
WP_VERSION=latest
WP_LOCALE=en_US
WORDPRESS_SITE_TITLE=My Website
WORDPRESS_ADMIN_USER=admin
# CHANGE THIS: WordPress admin password
WORDPRESS_ADMIN_PASSWORD=changeme
# CHANGE THIS: WordPress admin email
WORDPRESS_ADMIN_EMAIL=admin@example.com

# --- Cache Mode ---
# Options: fastcgi-cache, wp-rocket, cache-enabler, wp-super-cache, redis-cache
CACHE_MODE=fastcgi-cache

# --- Multisite ---
# Options: no, subdirectory, subdomain
WP_MULTISITE=no

# --- SSL ---
# Set to 1 after obtaining SSL certificate
SSL=0
SSL_EMAIL=admin@example.com
# Set to 1 for Let's Encrypt staging (testing)
SSL_STAGING=0
